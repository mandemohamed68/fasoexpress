rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function existing() { return resource.data; }
    function incoming() { return request.resource.data; }
    function isVerified() { return isSignedIn(); }
    
    function isAdmin() { 
      let hasEmail = request.auth.token.get('email', '') != '';
      return isSignedIn() && (
        (hasEmail && request.auth.token.email == 'mandemohamed6868@gmail.com') ||
        (hasEmail && request.auth.token.email == 'mandemohamed68@gmail.com') ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'superadmin'])
      ); 
    }
    
    function isDriver() {
      return isSignedIn() && (
             isAdmin() ||
             (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
              get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'driver')
      );
    }

    match /users/{userId} {
      function isValidUser(data) {
        return (data.userId == request.auth.uid || isAdmin()) &&
               data.role in ['client', 'driver', 'admin', 'superadmin'] &&
               data.role.size() < 12 &&
               data.role is string &&
               data.name is string && data.name.size() <= 100 &&
               data.email is string && data.email.size() <= 100;
      }
      
      allow get: if isSignedIn();
      allow list: if isSignedIn() && (isAdmin() || resource.data.role in ['driver', 'admin', 'superadmin']);
      allow create: if isSignedIn() && isValidId(userId) && isValidUser(incoming());
      allow update: if (isSignedIn() && request.auth.uid == userId && 
                       incoming().diff(existing()).affectedKeys().hasOnly(['name', 'role', 'status', 'accountStatus', 'currentLocation', 'updatedAt', 'phone', 'vehicleType', 'licensePlate', 'isVerified', 'withdrawalRequested', 'withdrawalAmount', 'rating', 'totalDeliveries', 'email', 'driverType', 'address', 'termsAcceptedAt', 'verificationStatus', 'guarantorName', 'guarantorPhone', 'identityCardUrl', 'criminalRecordUrl'])) || isAdmin();
      allow delete: if isAdmin() && existing().email != 'mandemohamed68@gmail.com';
    }

    match /settings/{settingId} {
      allow read: if true; 
      allow write: if isAdmin();
    }

    match /sectors/{sectorId} {
      allow read: if true; 
      allow write: if isAdmin();
    }

    match /announcements/{announcementId} {
      allow read: if true; 
      allow write: if isAdmin();
    }

    match /deliveries/{deliveryId} {
      function isValidDelivery(data) {
        return data.status in ['pending', 'accepted', 'picked_up', 'delivered', 'cancelled'] &&
               data.from.lat is number && data.from.lng is number &&
               data.to.lat is number && data.to.lng is number;
      }

      allow get: if isSignedIn() && (
        resource == null ||
        isAdmin() ||
        request.auth.uid == existing().clientId || 
        request.auth.uid == existing().driverId || 
        (existing().status == 'pending' && isDriver())
      );
      
      allow list: if isSignedIn() && (
        isAdmin() || 
        resource.data.clientId == request.auth.uid || 
        resource.data.driverId == request.auth.uid || 
        (resource.data.status == 'pending' && isDriver())
      );

      allow create: if isSignedIn() && isValidId(deliveryId) && (incoming().clientId == request.auth.uid || isAdmin()) && isValidDelivery(incoming()) && incoming().status == 'pending';
      allow delete: if isAdmin() || (isSignedIn() && existing().clientId == request.auth.uid);
      allow update: if isSignedIn() && isValidDelivery(incoming()) && (
        isAdmin() ||
        // Action: Client accepts a bid (sets driver and cost)
        (request.auth.uid == existing().clientId &&
         existing().status == 'pending' &&
         incoming().status == 'accepted' &&
         incoming().diff(existing()).affectedKeys().hasOnly(['status', 'driverId', 'driverName', 'cost', 'updatedAt', 'vehicleType', 'paymentMethod', 'isPaid', 'paymentStatus', 'pickupCode', 'deliveryCode', 'clientProposedPrice'])) ||
        // Action: Driver accepts job directly at client price
        (isDriver() && 
         existing().status == 'pending' &&
         incoming().status == 'accepted' &&
         incoming().driverId == request.auth.uid &&
         incoming().diff(existing()).affectedKeys().hasOnly(['status', 'driverId', 'driverName', 'cost', 'updatedAt'])) ||
        // Action: Driver updates status
        (request.auth.uid == existing().driverId &&
         incoming().status in ['accepted', 'picked_up', 'delivered'] &&
         incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt', 'currentLocation', 'isWeatherPaused', 'sosAlert', 'sosReason', 'proofImage'])) ||
        // Action: Driver cancels job (returns to pending)
        (request.auth.uid == existing().driverId &&
         incoming().status == 'pending' &&
         incoming().diff(existing()).affectedKeys().hasOnly(['status', 'driverId', 'driverName', 'updatedAt'])) ||
        // Action: Client cancels
        (request.auth.uid == existing().clientId &&
         existing().status in ['pending', 'accepted'] &&
         incoming().status == 'cancelled' &&
         incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt'])) ||
        // Action: Client pays or rates
        (request.auth.uid == existing().clientId &&
         incoming().diff(existing()).affectedKeys().hasOnly(['isPaid', 'paymentMethod', 'paymentStatus', 'pickupCode', 'deliveryCode', 'rating', 'feedback', 'updatedAt'])) ||
        // Action: Driver/Client updates chat-related or other permitted fields
        ((request.auth.uid == existing().clientId || request.auth.uid == existing().driverId) &&
         incoming().diff(existing()).affectedKeys().hasOnly(['updatedAt', 'lastMessageAt']))
      );
    }


    match /deliveries/{deliveryId}/messages/{messageId} {
      function isValidMessage(data) {
        return data.text is string && data.text.size() <= 1000 &&
               data.senderId == request.auth.uid &&
               data.senderName is string && data.senderName.size() <= 100 &&
               data.senderRole in ['client', 'driver', 'admin'] &&
               data.createdAt == request.time;
      }

      allow read: if isSignedIn() && (
        isAdmin() ||
        !exists(/databases/$(database)/documents/deliveries/$(deliveryId)) ||
        request.auth.uid == get(/databases/$(database)/documents/deliveries/$(deliveryId)).data.clientId ||
        request.auth.uid == get(/databases/$(database)/documents/deliveries/$(deliveryId)).data.driverId
      );
      
      allow create: if isSignedIn() && isValidId(messageId) && (
        isAdmin() ||
        request.auth.uid == get(/databases/$(database)/documents/deliveries/$(deliveryId)).data.clientId ||
        request.auth.uid == get(/databases/$(database)/documents/deliveries/$(deliveryId)).data.driverId
      ) && isValidMessage(incoming());
      
      allow update, delete: if isAdmin();
    }

    match /deliveries/{deliveryId}/bids/{driverId} {
      allow get: if isSignedIn() && (
        isAdmin() || 
        request.auth.uid == driverId || 
        get(/databases/$(database)/documents/deliveries/$(deliveryId)).data.clientId == request.auth.uid ||
        get(/databases/$(database)/documents/deliveries/$(deliveryId)).data.driverId == request.auth.uid
      );
      
      allow list: if isSignedIn() && (
        isAdmin() || 
        get(/databases/$(database)/documents/deliveries/$(deliveryId)).data.clientId == request.auth.uid ||
        get(/databases/$(database)/documents/deliveries/$(deliveryId)).data.driverId == request.auth.uid
      );
      
      allow create, update: if isDriver() && 
                    request.auth.uid == driverId && 
                    get(/databases/$(database)/documents/deliveries/$(deliveryId)).data.status == 'pending' &&
                    incoming().price is number && incoming().price > 0 &&
                    incoming().driverId == request.auth.uid;
      
      allow delete: if request.auth.uid == driverId || isAdmin();
    }

    function canTrack(dId) {
      let delivery = get(/databases/$(database)/documents/deliveries/$(dId)).data;
      return isSignedIn() && (
        request.auth.uid == delivery.clientId || 
        request.auth.uid == delivery.driverId || 
        isAdmin()
      );
    }
    
    match /deliveries/{deliveryId}/tracking/{trackId} {
      allow read: if canTrack(deliveryId);
      allow create: if isVerified() && request.auth.uid == get(/databases/$(database)/documents/deliveries/$(deliveryId)).data.driverId;
      allow delete: if isAdmin();
    }

    match /notifications/{notificationId} {
      function isValidNotification(data) {
        return data.userId is string && data.userId.size() <= 128 &&
               data.title is string && data.title.size() <= 100 &&
               data.message is string && data.message.size() <= 500 &&
               data.type in ['info', 'success', 'warning', 'error'] &&
               data.isRead is bool;
      }
      
      allow read, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidNotification(incoming());
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid && 
                    incoming().diff(existing()).affectedKeys().hasOnly(['isRead']) &&
                    incoming().isRead is bool;
    }
  }
}
