# Configuration du Serveur Local FASO EXPRESS

# Port du serveur (3000 obligatoire pour cet environnement)
PORT=3000

# Secret pour les tokens JWT (A CHANGER IMPERATIVEMENT)
JWT_SECRET=votre_secret_tres_long_et_complexe_ici

# Chemin vers la base de données SQLite (par défaut)
DATABASE_URL=./local.db

# Configuration MariaDB (Si DB_HOST est renseigné, SQLite est ignoré)
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_USER=faso_user
# DB_PASSWORD=mot_de_passe_super_secret
# DB_NAME=faso_livraison_db

# Configuration Sappay
SAPPAY_CLIENT_ID=
SAPPAY_CLIENT_SECRET=
SAPPAY_USERNAME=
SAPPAY_PASSWORD=

# Mode Environnement
NODE_ENV=production

# Base URL for API (for APK configuration)
VITE_API_BASE=http://41.78.54.60:3006/api